# ====================================================================
# Secrets & Environment Variables (CRITICAL)
# ====================================================================
.env
.env.local
.env.*.local
*.env
# Ensure you DO NOT ignore your template file
!.env.template

# ====================================================================
# TypeScript / Build / Bundling Outputs
# ====================================================================
# If you use Webpack/Babel/Vite to transpile your TypeScript scripts
dist/
build/
out/

# Dependency directories
node_modules/
jspm_packages/
.pnp/
.pnp.js

# TypeScript compilation cache and logs
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ====================================================================
# Test Results & k6 Reports
# ====================================================================
# HTML, JSON, or CSV reports generated by k6 extensions or custom scripts
*.html
*.json
*.csv
!package.json
!tsconfig.json

# Trace or debugging dumps
*.trace

# ====================================================================
# IDEs and Editors
# ====================================================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# ====================================================================
# OS-specific files
# ====================================================================
.DS_Store
Thumbs.db